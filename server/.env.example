APP_ENV=production
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ALLOW_DEV_USER_HEADER=false
OPENAI_API_KEY=your_openai_api_key
OPENAI_STT_MODEL=gpt-4o-transcribe
OPENAI_STT_LANGUAGE=ko
OPENAI_STT_PROMPT=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TEXT_PROMPT=
OPENAI_FEED_MODEL=gpt-4.1-mini
OPENAI_FEED_PROMPT=
OPENAI_MEMORY_MODEL=gpt-4.1-mini
OPENAI_MEMORY_PROMPT=
OPENAI_CHAPTER_MODEL=gpt-4.1-mini
OPENAI_CHAPTER_PROMPT=
OPENAI_SAFETY_MODEL=gpt-4.1-mini
OPENAI_SAFETY_PROMPT=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_FORMAT=mp3
OPENAI_TTS_PUBLIC_PATH=/generated-audio
OPENAI_TTS_OUTPUT_DIR=.generated-audio
OPENAI_TTS_INSTRUCTIONS=
OPENAI_TTS_RETENTION_HOURS=24
